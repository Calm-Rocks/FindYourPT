# Copy this file to .env.local and fill in your own Supabase project values.
# Find these in your Supabase project dashboard under Project Settings > API.
# VITE_-prefixed variables are safe to expose to the browser — the anon key
# is designed to be public; Row Level Security is what actually protects data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
